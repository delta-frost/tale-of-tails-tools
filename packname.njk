---
layout: base.njk
title: "Pack Name Generator"
---
<div id="generatorOutput" style="text-align: center; margin: 2rem 0;">
  <p style="font-style: italic; color: var(--text-secondary);">
    Your generated pack name will appear here.
  </p>
</div>

<div class="btn-group">
  <button id="generateBtn">
    <img src="{{ '/assets/icons/packlead.webp' | url }}" alt="" class="btn-icon"> Generate Name
  </button>

  <button
    x-data="{ copied: false }"
    @click="
      const packName = document.getElementById('packNameDisplay')?.textContent || '';
      const titleEl = document.querySelector('#generatorOutput p:nth-of-type(1)');
      const meaningEl = document.querySelector('#generatorOutput p:nth-of-type(2)');
      const title = titleEl?.textContent || '';
      const meaning = meaningEl?.textContent || '';
      const text = `Pack: ${packName} · ${title} · ${meaning}`;
      navigator.clipboard.writeText(text).then(() => {
        copied = true;
        setTimeout(() => copied = false, 1500);
      });
    "
    class="secondary"
    aria-label="Copy pack name to clipboard"
  >
    <img src="{{ '/assets/icons/pencil.webp' | url }}" alt="" class="btn-icon">
    <span x-text="copied ? '✓ Copied!' : 'Copy Name'"></span>
  </button>
</div>

<div class="notes">
  <strong>Notes</strong>
  <p>
    - All names are based in Welsh, which is where the 'meaning' comes from. Please feel free to point out any translation errors!
  </p>
  <p>
    - Titles are generated separately from names.
  </p>
</div>

<script src="{{ '/scripts/packname.js' | url }}"></script>
