<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} – Tale of Tails Tools</title>
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  <link rel="icon" type="image/webp" href="{{ '/assets/icons/wolfpaw.webp' | url }}">
<script>
  (function() {
    var saved = localStorage.getItem('theme');
    if (saved) {
      document.documentElement.className = saved;
    } else {
      document.documentElement.className = 'theme-erroa';
    }
  })();
</script>
</head>
<body>
  <div class="container">
    <!-- Theme picker (same across all pages) -->
<div class="theme-picker"
     x-data="{
         theme: localStorage.getItem('theme') || 'theme-erroa',
         icons: {
             'theme-erroa': '{{ '/assets/icons/erroa.webp' | url }}',
             'theme-gwanwyn': '{{ '/assets/icons/gwanwyn.webp' | url }}',
             'theme-tonnau': '{{ '/assets/icons/tonnau.webp' | url }}'
         },
         init() {
             document.documentElement.className = this.theme;
         },
         switchTheme(newTheme) {
             this.theme = newTheme;
             document.documentElement.className = newTheme;
             localStorage.setItem('theme', newTheme);
         }
     }">
    <label for="themeSelect">Theme:</label>
    <select id="themeSelect"
            x-model="theme"
            @change="switchTheme($el.value)">
        <option value="theme-erroa">
            <img src="{{ '/assets/icons/erroa.webp' | url }}" alt="" class="theme-icon-small"> Erroa
        </option>
        <option value="theme-gwanwyn">
            <img src="{{ '/assets/icons/gwanwyn.webp' | url }}" alt="" class="theme-icon-small"> Gwanwyn
        </option>
        <option value="theme-tonnau">
            <img src="{{ '/assets/icons/tonnau.webp' | url }}" alt="" class="theme-icon-small"> Tonnau
        </option>
    </select>

    <!-- Optional pack icon – only if you have <img id="currentPackIcon"> somewhere -->
    <img id="currentPackIcon"
         :src="icons[theme]"
         alt="Pack icon"
         style="width: 1.6rem; height: 1.6rem; vertical-align: middle; margin-left: 0.5rem;" />
</div>

    <!-- Header with logo + dynamic title -->
    <div class="header">
      <div class="wolf-logo">
        <a href="{{ '/' | url }}"><img src="{{ '/assets/icons/static-logo.png' | url }}" style="width:30%;" alt="Logo"></a>
      </div>
      <h1>{{ title }}</h1>
    </div>

    <!-- Unique page content injected below -->
    {{ content | safe }}
  </div>

  <!--
  ===== FOOTER PLACEHOLDER =====
  Uncomment and fill with your links when ready.
  You can also move this inside the .container div if you prefer.
  <footer>
    <p style="font-size: 0.8rem; text-align: center; margin-top: 2rem;">
      <a href="/about">About</a> •
      <a href="/credits">Credits</a> •
      <a href="https://discord.gg/kAu4btGGDJ">Discord</a> •
      Contact Saturday: <a href="mailto:you@example.com">email</a>
    </p>
  </footer>
  -->
	<!-- Give JavaScript the site base URL (works with any pathPrefix) -->
	<script>window.siteBase = "{{ '/' | url }}";</script>
	<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
	<!-- Animated Logo script -->
	<script>
  (function() {
    const logoImg = document.querySelector('.wolf-logo img');
    if (!logoImg) return;
    const staticSrc = logoImg.src;
    const animatedSrc = '{{ '/assets/icons/logo.webp' | url }}';  // adjust if different
    logoImg.addEventListener('mouseenter', () => { logoImg.src = animatedSrc; });
    logoImg.addEventListener('mouseleave', () => { logoImg.src = staticSrc; });
  })();
</script>
</body>
</html>
